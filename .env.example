# TRIP — Token Round-trip Inspection Profiler
# API Keys — copy this file to .env and fill in your values
#   cp .env.example .env

# OpenCode (opencode.ai / zen gateway)
# Used by: deepseek-v4-flash, deepseek-v4-pro, minimax-m2.*, kimi-*, glm-*, qwen*, mimo-*, hy3-preview
OPENCODE_API_KEY=sk-your-opencode-api-key-here

# xAI (api.x.ai)
# Used by: grok-4.20-*, grok-4.3
XAI_API_KEY=xai-your-xai-api-key-here

# OpenRouter (openrouter.ai)
# Used by: or-claude-*, or-gpt-*, or-deepseek-*, or-gemini-*, or-llama4-*, or-qwen3-*
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key-here

# DeepSeek (api.deepseek.com)
# Used by: ds-deepseek-v4-flash, ds-deepseek-chat, ds-deepseek-reasoner
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# Local inference (LM Studio on localhost:1234)
# Leave blank if no auth is required
LOCAL_API_KEY=